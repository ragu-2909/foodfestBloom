NODE_ENV=development
PORT=3000
APP_VERSION=0.1.0

# Frontend URL allowed by CORS. Use your Vercel domain in production.
FRONTEND_ORIGIN=http://localhost:5173
# Optional comma-separated list. Useful when allowing localhost plus Vercel preview/production URLs.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Use a pooled Postgres connection string in hosted/free-tier deployments.
DATABASE_URL=postgres://foodfest:foodfest@localhost:5432/foodfest
PG_POOL_MAX=12

# Admin login for the first production version.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234
JWT_SECRET=change-this-long-random-secret

# Cloudflare Tunnel should point api.domain.com to localhost:3000.
PUBLIC_API_URL=https://backend.ragu2909.pw
