NODE_ENV=production
PORT=3000
APP_VERSION=0.1.0

# This deployment is fully self-contained on one host: nginx (the "web"
# compose service) serves the frontend and proxies /api/ to the api
# container over the internal docker network, so the browser only ever
# talks to this same host/IP. No external domain or tunnel is involved.
#
# FRONTEND_ORIGIN/CORS_ORIGINS only matter if something other than the
# bundled nginx proxy talks to the api directly (e.g. `npm run dev:web`
# against a local api during development).
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgres://foodfest:foodfest@localhost:5432/foodfest
PG_POOL_MAX=12

# Admin login for the first production version.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234
JWT_SECRET=change-this-long-random-secret

# Baked into the web build at `docker compose build`. Leave as /api: nginx
# proxies that path to the api container, so no host/IP needs to be known
# ahead of time and nothing ever leaves the server.
PUBLIC_API_URL=/api
